# Dispatch configuration.
# Copy to `.env` for local runs. NEVER commit a real .env (it is gitignored).
# The default rules-based engine needs NO secrets at all — this file exists so the
# deployment is secret-ready if you later add an optional LLM provider.

# Port the server binds to (most hosts inject this automatically).
PORT=8000

# --- Optional, currently unused ---
# If you ever enable an LLM fallback, put the key here and read it via os.environ.
# DISPATCH_LLM_PROVIDER=
# ANTHROPIC_API_KEY=
